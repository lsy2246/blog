---
import Layout from "@/components/layout/Layout.astro";
import HomeDiorama from "@/components/home/HomeDiorama.astro";
import { SITE_META } from "@/consts";

export const prerender = true;

const homeProfile = {
  title: "lsy",
  kicker: "相由心生,意由境转",
  description: SITE_META.description,
  role: "Full-stack builder",
  summary:
    "Full-stack builder working with AI, writing, and the world outside the screen.",
  status: "still building · still noticing",
  stack: "React · TypeScript · Rust",
  contact: "lsy22@vip.qq.com",
  typewriterLines: ["today in echoes", "local workspace", "updating"],
} as const;
---

<Layout
  title={`${homeProfile.title} | ${SITE_META.title}`}
  description={homeProfile.description}
  contentLayout="custom"
  hideFooter={true}
  headerMode="overlay"
>
  <HomeDiorama profile={homeProfile} />
</Layout>
